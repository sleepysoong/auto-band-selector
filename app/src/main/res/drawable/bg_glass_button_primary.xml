<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#80FF5E62"
                android:endColor="#80FF9966"
                android:angle="45" />
            <corners android:radius="16dp" />
            <stroke
                android:width="2dp"
                android:color="#FFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#4DFF5E62"
                android:endColor="#4DFF9966"
                android:angle="45" />
            <corners android:radius="16dp" />
            <stroke
                android:width="2dp"
                android:color="#A0FFFFFF" />
        </shape>
    </item>
</selector>
