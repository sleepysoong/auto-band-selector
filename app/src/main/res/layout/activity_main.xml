<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_liquid"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- App Header Title -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auto Band Selector"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="28dp"
            android:shadowColor="#40000000"
            android:shadowDx="0"
            android:shadowDy="4"
            android:shadowRadius="8" />

        <!-- Card 1: Accessibility Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Accessibility Service"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Required to automate the hidden system settings dialer macro."
                android:textColor="#E0FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnEnableAccessibility"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_button"
                android:text="Enable Accessibility"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Card 2: Carrier Configuration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. Carrier Configuration"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose your carrier to apply the correct password automatically."
                android:textColor="#E0FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="14dp" />

            <RadioGroup
                android:id="@+id/rgCarrier"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbSkt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SKT (996412)"
                    android:textColor="#FFFFFF"
                    android:buttonTint="#FFFFFF"
                    android:checked="true"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp"/>

                <RadioButton
                    android:id="@+id/rbKt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KT (774632)"
                    android:textColor="#FFFFFF"
                    android:buttonTint="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp"/>

                <RadioButton
                    android:id="@+id/rbUplus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LGU+ (0821)"
                    android:textColor="#FFFFFF"
                    android:buttonTint="#FFFFFF"
                    android:textSize="14sp" />
            </RadioGroup>
        </LinearLayout>

        <!-- Card 3: Execute Macros -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. Execute Control"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnRunMacro"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_button_primary"
                android:text="Force Fast Bands (B1, B7)"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:elevation="4dp" />

            <Button
                android:id="@+id/btnRevertAutomatic"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_button"
                android:text="Revert to Automatic"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Sleepysoong Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Developed by sleepysoong"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>
