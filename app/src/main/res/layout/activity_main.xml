<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_liquid"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- App Header Title -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="자동 주파수 고정기"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="@font/pretendard_font"
            android:letterSpacing="-0.05"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"
            android:shadowColor="#40000000"
            android:shadowDx="0"
            android:shadowDy="4"
            android:shadowRadius="8" />

        <!-- Card 0: Live Scan Progress & Countdown (Liquid Glass) -->
        <LinearLayout
            android:id="@+id/cardScanProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvScanStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="초기화 중..."
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/pretendard_font"
                android:letterSpacing="-0.05"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvScanCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3초 뒤 시작합니다..."
                android:textColor="#FFD54F"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/pretendard_font"
                android:letterSpacing="-0.05"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvScanResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="@font/pretendard_font"
                android:letterSpacing="-0.05"
                android:lineSpacingMultiplier="1.2" />
        </LinearLayout>

        <!-- Card 1: Accessibility Status -->
        <LinearLayout
            android:id="@+id/cardAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. 접근성 서비스 설정"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/pretendard_font"
                android:letterSpacing="-0.05"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="시스템 히든 메뉴 매크로 자동화를 실행하기 위해 접근성 권한 허용이 필요합니다."
                android:textColor="#E0FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/pretendard_font"
                android:letterSpacing="-0.05"
                android:layout_marginBottom="16dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnEnableAccessibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_button"
                android:text="접근성 권한 활성화하기"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:fontFamily="@font/pretendard_font"
                android:letterSpacing="-0.05" />
        </LinearLayout>

        <!-- Card 2: Carrier Configuration -->
        <LinearLayout
            android:id="@+id/cardCarrier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. 통신사 선택"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/pretendard_font"
                android:letterSpacing="-0.05"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="매크로 실행 시 히든 메뉴 비밀번호를 자동으로 입력하기 위해 가입된 통신사를 선택해주세요."
                android:textColor="#E0FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/pretendard_font"
                android:letterSpacing="-0.05"
                android:layout_marginBottom="14dp" />

            <RadioGroup
                android:id="@+id/rgCarrier"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbSkt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SKT (비밀번호: 996412)"
                    android:textColor="#FFFFFF"
                    android:buttonTint="#FFFFFF"
                    android:checked="true"
                    android:textSize="14sp"
                    android:fontFamily="@font/pretendard_font"
                    android:letterSpacing="-0.05"
                    android:layout_marginBottom="4dp"/>

                <RadioButton
                    android:id="@+id/rbKt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KT (비밀번호: 774632)"
                    android:textColor="#FFFFFF"
                    android:buttonTint="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/pretendard_font"
                    android:letterSpacing="-0.05"
                    android:layout_marginBottom="4dp"/>

                <RadioButton
                    android:id="@+id/rbUplus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LGU+ (비밀번호: 0821)"
                    android:textColor="#FFFFFF"
                    android:buttonTint="#FFFFFF"
                    android:fontFamily="@font/pretendard_font"
                    android:letterSpacing="-0.05"
                    android:textSize="14sp" />
            </RadioGroup>
        </LinearLayout>

        <!-- Card 3: Execute Macros -->
        <LinearLayout
            android:id="@+id/cardExecute"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. 실행 및 제어"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/pretendard_font"
                android:letterSpacing="-0.05"
                android:layout_marginBottom="12dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRunMacro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_button_primary"
                android:text="자동 주파수 스캔 시작 (3초 카운트다운)"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textStyle="bold"
                android:fontFamily="@font/pretendard_font"
                android:letterSpacing="-0.05"
                android:layout_marginBottom="12dp"
                android:elevation="4dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRevertAutomatic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_button"
                android:text="일반 자동 선택 모드로 복구"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:fontFamily="@font/pretendard_font"
                android:letterSpacing="-0.05" />
        </LinearLayout>

        <!-- Sleepysoong Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="sleepysoong 제작"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:fontFamily="@font/pretendard_font"
            android:letterSpacing="-0.05"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>
